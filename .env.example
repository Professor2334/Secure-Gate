# Database connection string for PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/securegate?schema=public"

# NextAuth session signing key (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your_nextauth_secret_key"
# NextAuth application canonical URL
NEXTAUTH_URL="http://localhost:3000"

# Resend API Key for transactional email sending
RESEND_API_KEY="re_your_api_key"
# From address for sent emails
RESEND_FROM="onboarding@resend.dev"

# Upstash Redis API credentials for rate limiting
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_redis_token"
